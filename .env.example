# PostgreSQL
POSTGRES_DB=ai_risk
POSTGRES_USER=ai_risk
POSTGRES_PASSWORD=ai_risk_dev_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Django
DJANGO_SECRET_KEY=dev-only-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Celery (Redis broker)
# CELERY_BROKER_URL is set automatically in docker-compose; override here if running outside Docker
# CELERY_BROKER_URL=redis://localhost:6379/0

# ── Optional integrations ──────────────────────────────────────────────────────
# Leave empty to disable the integration. The platform starts and runs without them.

# GitHub MCP — enables GitHub tools inside Claude Code (issues, PRs, code search).
# Generate at: https://github.com/settings/tokens  (scope: repo, read:org)
AI_MCP_GITHUB_TOKEN=

# Notification gateway — required only for live Merchant/ISO/Agent notifications.
# SENDGRID_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Mainframe adapter — required only for wc3270 hold/release execution.
# TSYS_HOST=
# TSYS_PORT=
# TSYS_USER=
# TSYS_PASSWORD=
