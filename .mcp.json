{
  "mcpServers": {
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ]
    },
    "github": {
      "type": "stdio",
      "command": "sh",
      "args": [
        "-c",
        "[ -z \"$AI_MCP_GITHUB_TOKEN\" ] && exit 0; GITHUB_PERSONAL_ACCESS_TOKEN=\"$AI_MCP_GITHUB_TOKEN\" exec npx -y @modelcontextprotocol/server-github"
      ]
    }
  }
}
